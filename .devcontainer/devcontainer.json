{
  "name": "Claude Code Sandbox",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "TZ": "${localEnv:TZ:America/Los_Angeles}",
      "CLAUDE_CODE_VERSION": "latest",
      "GIT_DELTA_VERSION": "0.18.2",
      "ZSH_IN_DOCKER_VERSION": "1.2.0"
    }
  },
  "runArgs": [
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW",
    "--sysctl=net.ipv6.conf.all.disable_ipv6=0"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "eamodio.gitlens"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "explicit"
        },
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "bash": {
            "path": "bash",
            "icon": "terminal-bash"
          },
          "zsh": {
            "path": "zsh"
          }
        }
      }
    }
  },
  "remoteUser": "node",
  "mounts": [
    "source=claude-code-bashhistory-${devcontainerId},target=/commandhistory,type=volume",
    "source=claude-code-config-${devcontainerId},target=/home/node/.claude,type=volume",
    "source=tailscale-state-${devcontainerId},target=/tmp/tailscale,type=volume"
  ],
  "containerEnv": {
    "NODE_OPTIONS": "--max-old-space-size=4096",
    "CLAUDE_CONFIG_DIR": "/home/node/.claude",
    "POWERLEVEL9K_DISABLE_GITSTATUS": "true",
    "TAILSCALE_AUTHKEY": "${localEnv:TAILSCALE_AUTHKEY:}",
    "TAILSCALE_HOSTNAME": "${localEnv:TAILSCALE_HOSTNAME:claude-dev}",
    "TAILSCALE_SERVE_PORT": "${localEnv:TAILSCALE_SERVE_PORT:3000}",
    "REMOTE_CONTROL_NAME": "${localEnv:REMOTE_CONTROL_NAME:Claude Dev}",
    "FIREWALL_EXTRA_DOMAINS": "${localEnv:FIREWALL_EXTRA_DOMAINS:}",
    "FIREWALL_IPV6_HOSTS": "${localEnv:FIREWALL_IPV6_HOSTS:}"
  },
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Dev Server",
      "onAutoForward": "notify"
    }
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace",
  "postStartCommand": "test -f /workspace/.env.devcontainer && set -a && . /workspace/.env.devcontainer && set +a; for f in /workspace/*/.env.devcontainer; do test -f \"$f\" && set -a && . \"$f\" && set +a; done; sudo /usr/local/bin/init-firewall.sh && /usr/local/bin/start-tailscale.sh && nohup /usr/local/bin/start-remote-control.sh &",
  "postAttachCommand": "claude --dangerously-skip-permissions",
  "waitFor": "postStartCommand"
}
