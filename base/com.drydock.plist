<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<!--
  Drydock daemon — macOS launchd user agent.
  User-level service, starts on login, RestartOnFailure semantics,
  logs to ~/.drydock/logs/daemon-launchd.log.

  Install:
    cp base/com.drydock.plist ~/Library/LaunchAgents/
    launchctl load ~/Library/LaunchAgents/com.drydock.plist

  Uninstall:
    launchctl unload ~/Library/LaunchAgents/com.drydock.plist
    rm ~/Library/LaunchAgents/com.drydock.plist

  The daemon reads ~/.drydock/daemon.toml for config (secrets backend, etc.).
  Socket path: ~/.drydock/run/daemon.sock (default).
-->
<dict>
    <key>Label</key>
    <string>com.drydock</string>

    <key>ProgramArguments</key>
    <array>
        <!-- Adjust path if drydock is installed elsewhere -->
        <string>/Users/stevenfan/.local/bin/drydock</string>
        <string>daemon</string>
        <string>start</string>
        <string>--foreground</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/stevenfan/.drydock/logs/daemon-launchd.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/stevenfan/.drydock/logs/daemon-launchd.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/Users/stevenfan/.local/bin</string>
    </dict>

    <key>ThrottleInterval</key>
    <integer>5</integer>
</dict>
</plist>
