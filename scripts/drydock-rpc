#!/usr/bin/env python3
"""drydock-rpc — in-desk JSON-RPC client for the wsd daemon.

Designed to run inside a drydock container, reaching the Harbor-side
`wsd` via the bind-mounted Unix socket. Equivalent surface to
`src/drydock/cli/_wsd_client.py` but stdlib-only so it can ship as a
single executable into `drydock-base`-derived containers without
pulling in the full drydock Python package.

Usage examples (from inside a drydock):

    # Health check
    drydock-rpc wsd.health

    # Identify the caller's desk (uses drydock-token from /run/secrets/)
    drydock-rpc wsd.whoami

    # List all drydocks visible on this Harbor
    drydock-rpc ListDesks

    # Cross-desk secret delegation (V2.1): caller asks wsd for a lease
    # on infra's claude_credentials, materialized into this drydock
    # at /run/secrets/claude_credentials.
    drydock-rpc RequestCapability \\
        type=SECRET \\
        scope.secret_name=claude_credentials \\
        scope.source_desk_id=ws_infra

Dotted keys (`scope.foo=bar`) build nested dicts. Values are JSON-parsed
when they look like JSON (`true`, `42`, `null`, strings-with-quotes);
otherwise passed through as raw strings.

Auth: reads `/run/secrets/drydock-token` if present and sends it as the
`auth` field of every request. That is how wsd derives the subject
desk_id for `RequestCapability` (see v2-design-protocol.md §5).

Socket path: `$DRYDOCK_WSD_SOCKET`, default `/run/drydock/wsd.sock`.
"""
from __future__ import annotations

import argparse
import json
import os
import socket
import sys
import uuid
from pathlib import Path

DEFAULT_SOCKET = "/run/drydock/wsd.sock"
DEFAULT_TOKEN_PATH = "/run/secrets/drydock-token"
DEFAULT_TIMEOUT = 30.0


def parse_value(raw: str) -> object:
    """Parse a CLI value: JSON if it looks like JSON, else raw string."""
    raw_stripped = raw.strip()
    if not raw_stripped:
        return raw
    if raw_stripped[0] in "{[\"" or raw_stripped in ("true", "false", "null"):
        try:
            return json.loads(raw_stripped)
        except json.JSONDecodeError:
            return raw
    # Numeric fast-path
    try:
        if "." in raw_stripped:
            return float(raw_stripped)
        return int(raw_stripped)
    except ValueError:
        return raw


def set_nested(params: dict, dotted_key: str, value: object) -> None:
    """Assign value into params at a dotted path, creating nested dicts."""
    parts = dotted_key.split(".")
    cursor = params
    for part in parts[:-1]:
        if part not in cursor or not isinstance(cursor[part], dict):
            cursor[part] = {}
        cursor = cursor[part]
    cursor[parts[-1]] = value


def read_token(path: str) -> str | None:
    try:
        return Path(path).read_text(encoding="utf-8").strip() or None
    except (FileNotFoundError, PermissionError, OSError):
        return None


def call(
    method: str,
    params: dict,
    *,
    socket_path: str,
    request_id: str,
    auth: str | None,
    timeout: float,
) -> dict:
    payload: dict[str, object] = {
        "jsonrpc": "2.0",
        "id": request_id,
        "method": method,
        "params": params,
    }
    if auth:
        payload["auth"] = auth

    with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as client:
        client.settimeout(timeout)
        client.connect(socket_path)
        client.sendall((json.dumps(payload) + "\n").encode("utf-8"))

        buf = b""
        while not buf.endswith(b"\n"):
            chunk = client.recv(4096)
            if not chunk:
                break
            buf += chunk

    if not buf:
        raise RuntimeError("empty response from wsd")
    return json.loads(buf.decode("utf-8").strip())


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(
        prog="drydock-rpc",
        description="In-desk JSON-RPC client for the wsd daemon.",
    )
    parser.add_argument("method", help="RPC method name (e.g. wsd.health, RequestCapability)")
    parser.add_argument(
        "params",
        nargs="*",
        help="params as KEY=VALUE pairs; dotted keys build nested dicts",
    )
    parser.add_argument(
        "--socket",
        default=os.environ.get("DRYDOCK_WSD_SOCKET", DEFAULT_SOCKET),
        help=f"Unix socket path (default: $DRYDOCK_WSD_SOCKET or {DEFAULT_SOCKET})",
    )
    parser.add_argument(
        "--request-id",
        default=None,
        help="JSON-RPC request id (default: new UUIDv4)",
    )
    parser.add_argument(
        "--token-path",
        default=DEFAULT_TOKEN_PATH,
        help=f"Path to bearer token (default: {DEFAULT_TOKEN_PATH})",
    )
    parser.add_argument(
        "--no-auth",
        action="store_true",
        help="Skip reading bearer token (unauthenticated call)",
    )
    parser.add_argument(
        "--timeout",
        type=float,
        default=DEFAULT_TIMEOUT,
        help=f"Socket timeout in seconds (default: {DEFAULT_TIMEOUT})",
    )
    args = parser.parse_args(argv)

    params: dict = {}
    for kv in args.params:
        if "=" not in kv:
            print(f"drydock-rpc: bad param '{kv}' (expected KEY=VALUE)", file=sys.stderr)
            return 2
        key, _, raw_value = kv.partition("=")
        set_nested(params, key, parse_value(raw_value))

    auth = None if args.no_auth else read_token(args.token_path)
    request_id = args.request_id or str(uuid.uuid4())

    try:
        response = call(
            args.method,
            params,
            socket_path=args.socket,
            request_id=request_id,
            auth=auth,
            timeout=args.timeout,
        )
    except FileNotFoundError:
        print(f"drydock-rpc: socket not found at {args.socket}", file=sys.stderr)
        return 3
    except ConnectionRefusedError:
        print(f"drydock-rpc: connection refused at {args.socket} (is wsd running?)", file=sys.stderr)
        return 3
    except PermissionError as exc:
        print(f"drydock-rpc: permission denied on {args.socket} ({exc})", file=sys.stderr)
        return 3
    except (socket.timeout, TimeoutError):
        print(f"drydock-rpc: timed out after {args.timeout}s", file=sys.stderr)
        return 4
    except OSError as exc:
        print(f"drydock-rpc: socket error: {exc}", file=sys.stderr)
        return 3

    if "error" in response:
        err = response["error"]
        print(json.dumps(err, indent=2), file=sys.stderr)
        return 1
    if "result" in response:
        print(json.dumps(response["result"], indent=2))
        return 0

    print(json.dumps(response, indent=2), file=sys.stderr)
    print("drydock-rpc: malformed response (no result or error)", file=sys.stderr)
    return 5


if __name__ == "__main__":
    raise SystemExit(main())
