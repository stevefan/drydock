{
  "name": "collab",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "TZ": "${localEnv:TZ:America/Los_Angeles}"
    }
  },
  "runArgs": [
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW"
  ],
  "remoteUser": "node",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace",
  "forwardPorts": [],
  "postStartCommand": "test -f /workspace/.env.devcontainer && set -a && . /workspace/.env.devcontainer && set +a; sudo /usr/local/bin/init-firewall.sh && /usr/local/bin/start-tailscale.sh && /usr/local/bin/start-telegram-bot.sh; setsid -f /usr/local/bin/start-remote-control.sh > /tmp/remote-control.log 2>&1",
  "waitFor": "postStartCommand"
}
