#!/usr/bin/env python3
"""tg-send — post a message to the pinned Telegram chat.

Used by an in-desk Claude session to push status, results, or
conversation back into the chat without having to be invoked through
a slash command.

Reads the bot token from /run/secrets/telegram_bot_token and the
target chat ID from /workspace/telegram/chat_id (TOFU-pinned by the
bot on first contact).

Usage:
    tg-send "hello"
    echo "from stdin" | tg-send -
"""

from __future__ import annotations

import sys
import urllib.parse
import urllib.request
from pathlib import Path

TOKEN_PATH = Path("/run/secrets/telegram_bot_token")
CHAT_ID_PATH = Path("/workspace/telegram/chat_id")


def main() -> int:
    if len(sys.argv) < 2:
        sys.exit("usage: tg-send <message>  (or `tg-send -` to read stdin)")

    if sys.argv[1] == "-":
        text = sys.stdin.read().strip()
    else:
        text = " ".join(sys.argv[1:])

    if not text:
        sys.exit("empty message — refusing to send")

    if not TOKEN_PATH.exists():
        sys.exit(f"missing {TOKEN_PATH}: run `ws secret set <desk> telegram_bot_token`")
    if not CHAT_ID_PATH.exists():
        sys.exit(
            f"no pinned chat at {CHAT_ID_PATH}. The bot pins on first message; "
            "send anything in the bot's chat once, then retry."
        )

    token = TOKEN_PATH.read_text().strip()
    chat_id = CHAT_ID_PATH.read_text().strip()

    url = f"https://api.telegram.org/bot{token}/sendMessage"
    data = urllib.parse.urlencode({"chat_id": chat_id, "text": text}).encode()
    try:
        with urllib.request.urlopen(url, data=data, timeout=15) as resp:
            if resp.status != 200:
                sys.exit(f"telegram api returned {resp.status}: {resp.read()[:200]!r}")
    except Exception as exc:  # noqa: BLE001
        sys.exit(f"telegram send failed: {exc}")

    print("sent")
    return 0


if __name__ == "__main__":
    sys.exit(main())
